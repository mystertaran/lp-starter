# Google Analytics 4 measurement ID.
# Replace with your own G-XXXXXXXXXX to activate tracking.
# The root layout auto-disables GA when this is missing or still the placeholder.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Resend — contact form email delivery.
# Get a key at https://resend.com/api-keys (free tier covers prelaunch traffic).
RESEND_API_KEY=

# Optional overrides for the contact form email flow.
# Defaults: from=onboarding@resend.dev (Resend test domain), to=info@thefabos.pl.
# Replace CONTACT_FROM_EMAIL once you verify fabos.pl in the Resend dashboard.
# CONTACT_FROM_EMAIL=The Fabos <info@thefabos.pl>
# CONTACT_TO_EMAIL=info@thefabos.pl
