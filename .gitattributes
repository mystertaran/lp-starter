# Normalize line endings in the repo: always LF, regardless of platform.
* text=auto eol=lf

# Binary files — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.mp4 binary
*.mov binary
*.webm binary

# Lockfiles — keep as-is, don't diff
pnpm-lock.yaml -diff
